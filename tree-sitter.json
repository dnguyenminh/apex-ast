{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "apex",
      "camelcase": "Apex",
      "title": "Apex",
      "scope": "source.apex",
      "file-types": [
        "cls",
        "trigger"
      ],
      "injection-regex": "^apex$",
      "class-name": "TreeSitterApex"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parse Apex Programming language",
    "authors": [
      {
        "name": "Nguyen Minh Duc",
        "email": "dnguyenminh@gmail.com",
        "url": "https://www.linkedin.com/in/duc-nguyen-7bbb3827/"
      }
    ],
    "links": {
      "repository": "https://github.com/dnguyenminh/apex-ast",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}